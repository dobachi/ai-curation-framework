# Curation Local Runner - Environment Variables (bash)
#
# コピー先: ~/.config/curation/runner.env
# 使い方:
#   mkdir -p ~/.config/curation
#   cp local-runner/env.example ~/.config/curation/runner.env
#   # このファイルを編集

# リポジトリのローカルパス（必須）
CURATION_REPO="$HOME/Sources/curation-reports"

# ログディレクトリ
CURATION_LOG_DIR="$HOME/.local/share/curation/logs"

# claude CLI の追加引数
# --allowedTools でツール許可を事前付与（非対話実行のため必須）
# --max-turns で暴走防止
CURATION_CLAUDE_ARGS="--allowedTools Bash,Read,Write,Edit,Glob,Grep,WebSearch,WebFetch --max-turns 80"

# タイムゾーン
TZ="Asia/Tokyo"
